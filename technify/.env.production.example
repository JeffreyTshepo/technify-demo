# ============================================
# PRODUCTION TEMPLATE (Portfolio-safe)
# ============================================
# Upload this as `.env` on your hosting platform.
# Do not commit the real `.env` used in production.

# =========================
# Django core
# =========================
SECRET_KEY=GENERATE_A_NEW_SECRET_KEY
DJANGO_DEBUG=False
ALLOWED_HOSTS=your-domain.com

# =========================
# Database (MySQL example)
# =========================
DB_ENGINE=django.db.backends.mysql
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=3306

# =========================
# Security (HTTPS)
# =========================
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

# =========================
# Email (optional)
# =========================
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# =========================
# SMS (optional, Twilio)
# =========================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+27000000000

# =========================
# Payments (Yoco)
# =========================
# Keep this in test mode for portfolio deployments.
YOCO_MODE=test
YOCO_PUBLIC_KEY=pk_test_REPLACE_ME
YOCO_SECRET_KEY=sk_test_REPLACE_ME
YOCO_WEBHOOK_SECRET=
