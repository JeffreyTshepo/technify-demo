# Technify (Portfolio/Dev) environment template
#
# Create a local `.env` next to `manage.py` using these keys.
# Never commit your real `.env` file.

# =========================
# Django core
# =========================
DJANGO_DEBUG=True
SECRET_KEY=django-insecure-change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# =========================
# Database (optional)
# =========================
# Defaults to SQLite if DB_ENGINE is not set.
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=3306

# =========================
# Email (optional)
# =========================
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# =========================
# SMS (optional, Twilio)
# =========================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =========================
# Payments (Yoco)
# =========================
# Use TEST keys for portfolio demos.
YOCO_MODE=test
YOCO_PUBLIC_KEY=pk_test_REPLACE_ME
YOCO_SECRET_KEY=sk_test_REPLACE_ME
YOCO_WEBHOOK_SECRET=
